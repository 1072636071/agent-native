{
  "name": "Demo PostgreSQL SaaS Ops",
  "description": "Sample PostgreSQL operational metrics for exploring database health dashboards without connecting a database.",
  "columns": 3,
  "panels": [
    {
      "id": "overview",
      "title": "Database Overview",
      "chartType": "section",
      "width": 1,
      "columns": 3,
      "config": {
        "description": "Fixed-query demo rows that mimic common PostgreSQL health and performance metrics."
      }
    },
    {
      "id": "database-health",
      "title": "Health Snapshot",
      "source": "demo",
      "chartType": "table",
      "width": 1,
      "sql": "{\"adapter\":\"postgres\",\"dataset\":\"postgres-saas\",\"query\":\"database-health\"}",
      "config": {
        "columns": [
          { "key": "metric", "label": "Metric" },
          { "key": "value", "label": "Value", "format": "number" },
          { "key": "status", "label": "Status" }
        ],
        "limit": 10
      }
    },
    {
      "id": "connections-by-state",
      "title": "Connections by State",
      "source": "demo",
      "chartType": "area",
      "width": 2,
      "sql": "{\"adapter\":\"postgres\",\"dataset\":\"postgres-saas\",\"query\":\"connections-by-state\"}",
      "config": {
        "xKey": "timestamp",
        "yKey": "connections",
        "stacked": true,
        "pivot": {
          "xKey": "timestamp",
          "seriesKey": "state",
          "valueKey": "connections"
        }
      }
    },
    {
      "id": "query-latency",
      "title": "Query Latency",
      "source": "demo",
      "chartType": "line",
      "width": 2,
      "sql": "{\"adapter\":\"postgres\",\"dataset\":\"postgres-saas\",\"query\":\"query-latency\"}",
      "config": {
        "xKey": "timestamp",
        "yKey": "latencyMs",
        "pivot": {
          "xKey": "timestamp",
          "seriesKey": "percentile",
          "valueKey": "latencyMs"
        }
      }
    },
    {
      "id": "database-size",
      "title": "Database Size",
      "source": "demo",
      "chartType": "area",
      "width": 1,
      "sql": "{\"adapter\":\"postgres\",\"dataset\":\"postgres-saas\",\"query\":\"database-size\"}",
      "config": {
        "xKey": "timestamp",
        "yKey": "sizeGb",
        "stacked": true,
        "pivot": {
          "xKey": "timestamp",
          "seriesKey": "database",
          "valueKey": "sizeGb"
        }
      }
    },
    {
      "id": "slow-queries",
      "title": "Slow Query Samples",
      "source": "demo",
      "chartType": "table",
      "width": 3,
      "sql": "{\"adapter\":\"postgres\",\"dataset\":\"postgres-saas\",\"query\":\"slow-queries\"}",
      "config": {
        "columns": [
          { "key": "query", "label": "Query" },
          { "key": "calls", "label": "Calls", "format": "number" },
          { "key": "meanMs", "label": "Mean ms", "format": "number" },
          { "key": "p95Ms", "label": "P95 ms", "format": "number" }
        ],
        "limit": 10
      }
    }
  ]
}
