{
  "name": "Demo Node Exporter",
  "description": "Sample Prometheus-shaped node exporter data for exploring host observability dashboards without connecting Prometheus.",
  "columns": 3,
  "filters": [
    {
      "id": "instance",
      "type": "select",
      "label": "Instance",
      "default": "demo-host-01",
      "options": [
        { "value": "demo-host-01", "label": "demo-host-01" },
        { "value": "demo-host-02", "label": "demo-host-02" }
      ]
    }
  ],
  "panels": [
    {
      "id": "overview",
      "title": "Host Overview",
      "chartType": "section",
      "width": 1,
      "columns": 3,
      "config": {
        "description": "Prometheus-style rows with realistic node_exporter labels, generated locally as demo data."
      }
    },
    {
      "id": "node-up",
      "title": "Node Up",
      "source": "demo",
      "chartType": "metric",
      "width": 1,
      "sql": "{\"adapter\":\"prometheus\",\"dataset\":\"node-exporter\",\"query\":\"node-up\",\"mode\":\"instant\",\"params\":{\"instance\":\"{{instance}}\"}}",
      "config": {
        "yKey": "value",
        "description": "Scrape target health."
      }
    },
    {
      "id": "cpu-busy-by-mode",
      "title": "CPU Busy by Mode",
      "source": "demo",
      "chartType": "area",
      "width": 2,
      "sql": "{\"adapter\":\"prometheus\",\"dataset\":\"node-exporter\",\"query\":\"cpu-busy-by-mode\",\"mode\":\"range\",\"params\":{\"instance\":\"{{instance}}\"}}",
      "config": {
        "xKey": "timestamp",
        "yKey": "value",
        "yFormatter": "percent",
        "stacked": true,
        "pivot": {
          "xKey": "timestamp",
          "seriesKey": "series",
          "valueKey": "value"
        }
      }
    },
    {
      "id": "load-average",
      "title": "Load Average",
      "source": "demo",
      "chartType": "line",
      "width": 1,
      "sql": "{\"adapter\":\"prometheus\",\"dataset\":\"node-exporter\",\"query\":\"load-average\",\"mode\":\"range\",\"params\":{\"instance\":\"{{instance}}\"}}",
      "config": {
        "xKey": "timestamp",
        "yKey": "value",
        "pivot": {
          "xKey": "timestamp",
          "seriesKey": "series",
          "valueKey": "value"
        }
      }
    },
    {
      "id": "memory-composition",
      "title": "Memory Composition (GiB)",
      "source": "demo",
      "chartType": "area",
      "width": 2,
      "sql": "{\"adapter\":\"prometheus\",\"dataset\":\"node-exporter\",\"query\":\"memory-composition\",\"mode\":\"range\",\"params\":{\"instance\":\"{{instance}}\"}}",
      "config": {
        "xKey": "timestamp",
        "yKey": "value",
        "stacked": true,
        "pivot": {
          "xKey": "timestamp",
          "seriesKey": "series",
          "valueKey": "value"
        }
      }
    },
    {
      "id": "filesystem-usage",
      "title": "Filesystem Usage",
      "source": "demo",
      "chartType": "bar",
      "width": 1,
      "sql": "{\"adapter\":\"prometheus\",\"dataset\":\"node-exporter\",\"query\":\"filesystem-usage\",\"mode\":\"instant\",\"params\":{\"instance\":\"{{instance}}\"}}",
      "config": {
        "xKey": "series",
        "yKey": "value",
        "yFormatter": "percent"
      }
    },
    {
      "id": "network-throughput",
      "title": "Network Throughput",
      "source": "demo",
      "chartType": "line",
      "width": 1,
      "sql": "{\"adapter\":\"prometheus\",\"dataset\":\"node-exporter\",\"query\":\"network-throughput\",\"mode\":\"range\",\"params\":{\"instance\":\"{{instance}}\"}}",
      "config": {
        "xKey": "timestamp",
        "yKey": "value",
        "pivot": {
          "xKey": "timestamp",
          "seriesKey": "series",
          "valueKey": "value"
        }
      }
    },
    {
      "id": "disk-io",
      "title": "Disk IO",
      "source": "demo",
      "chartType": "line",
      "width": 1,
      "sql": "{\"adapter\":\"prometheus\",\"dataset\":\"node-exporter\",\"query\":\"disk-io\",\"mode\":\"range\",\"params\":{\"instance\":\"{{instance}}\"}}",
      "config": {
        "xKey": "timestamp",
        "yKey": "value",
        "pivot": {
          "xKey": "timestamp",
          "seriesKey": "series",
          "valueKey": "value"
        }
      }
    },
    {
      "id": "collector-status",
      "title": "Collector Status",
      "source": "demo",
      "chartType": "table",
      "width": 1,
      "sql": "{\"adapter\":\"prometheus\",\"dataset\":\"node-exporter\",\"query\":\"collector-status\",\"mode\":\"instant\",\"params\":{\"instance\":\"{{instance}}\"}}",
      "config": {
        "columns": [
          { "key": "collector", "label": "Collector" },
          { "key": "success", "label": "Success", "format": "number" },
          {
            "key": "durationSeconds",
            "label": "Duration (s)",
            "format": "number"
          }
        ],
        "limit": 10
      }
    }
  ]
}
