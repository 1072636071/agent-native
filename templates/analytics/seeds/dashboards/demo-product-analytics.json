{
  "name": "Demo Product Analytics",
  "description": "Sample product analytics metrics for exploring funnel and acquisition dashboards without connecting an event source.",
  "columns": 3,
  "panels": [
    {
      "id": "overview",
      "title": "Product Overview",
      "chartType": "section",
      "width": 1,
      "columns": 3,
      "config": {
        "description": "Synthetic event and session rows for first-run dashboard exploration."
      }
    },
    {
      "id": "kpi-summary",
      "title": "KPI Summary",
      "source": "demo",
      "chartType": "table",
      "width": 1,
      "sql": "{\"adapter\":\"events\",\"dataset\":\"product-analytics\",\"query\":\"kpi-summary\"}",
      "config": {
        "columns": [
          { "key": "metric", "label": "Metric" },
          { "key": "value", "label": "Value", "format": "number" },
          { "key": "delta", "label": "Delta", "format": "percent" }
        ],
        "limit": 10
      }
    },
    {
      "id": "signups-by-day",
      "title": "Signups and Activations",
      "source": "demo",
      "chartType": "line",
      "width": 2,
      "sql": "{\"adapter\":\"events\",\"dataset\":\"product-analytics\",\"query\":\"signups-by-day\"}",
      "config": {
        "xKey": "date",
        "yKeys": ["signups", "activated"]
      }
    },
    {
      "id": "sessions-by-channel",
      "title": "Sessions by Channel",
      "source": "demo",
      "chartType": "bar",
      "width": 1,
      "sql": "{\"adapter\":\"events\",\"dataset\":\"product-analytics\",\"query\":\"sessions-by-channel\"}",
      "config": {
        "xKey": "channel",
        "yKey": "sessions"
      }
    },
    {
      "id": "activation-funnel",
      "title": "Activation Funnel",
      "source": "demo",
      "chartType": "bar",
      "width": 1,
      "sql": "{\"adapter\":\"events\",\"dataset\":\"product-analytics\",\"query\":\"activation-funnel\"}",
      "config": {
        "xKey": "stage",
        "yKey": "users"
      }
    },
    {
      "id": "top-events",
      "title": "Top Events",
      "source": "demo",
      "chartType": "table",
      "width": 1,
      "sql": "{\"adapter\":\"events\",\"dataset\":\"product-analytics\",\"query\":\"top-events\"}",
      "config": {
        "columns": [
          { "key": "event", "label": "Event" },
          { "key": "count", "label": "Count", "format": "number" },
          { "key": "users", "label": "Users", "format": "number" }
        ],
        "limit": 10
      }
    }
  ]
}
